# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit real keys.
# Only the variables for the provider(s) you use are required.

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenRouter — https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Gloo AI Studio — https://studio.ai.gloo.com (Settings → API Credentials)
GLOO_CLIENT_ID=
GLOO_CLIENT_SECRET=

# Ollama — local inference via OpenAI-compatible API (https://ollama.com)
# Override to point at mlx_lm.server or any other OpenAI-compatible local endpoint.
OLLAMA_BASE_URL=http://localhost:11434/v1
